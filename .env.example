# Azure OpenAI (required for embeddings + LLM)
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_EMBED_DEPLOYMENT=embed-model
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-4o

# Azure AI Search (optional — enables dual-write in ingest_excel.py and migrate_to_search.py)
# Get these from: Azure Portal → AI Search resource → Keys
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-admin-key-here
AZURE_SEARCH_INDEX=work-orders
