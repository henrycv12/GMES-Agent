{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/favicon.ico"]
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  },
  "platform": {
    "apiRuntime": "node:18"
  }
}
